# Default: auto-detect text files and normalise line endings to LF in the repo
* text=auto

# Always store and checkout these files with LF (they break with CRLF)
.env*                  text eol=lf
Dockerfile             text eol=lf
docker-compose*.yml    text eol=lf
*.sh                   text eol=lf
*.ex                   text eol=lf
*.exs                  text eol=lf
*.heex                 text eol=lf

# Binary files — never mangle
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
